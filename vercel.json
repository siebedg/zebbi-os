{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci && npm ci --prefix web",
  "buildCommand": "npm run build --prefix web",
  "outputDirectory": "web/dist",
  "framework": "vite",
  "rewrites": [{ "source": "/((?!api/)(?!.*\\.).*)", "destination": "/index.html" }]
}
